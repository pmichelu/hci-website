generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model Post {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  body          String    @db.LongText
  excerpt       String?   @db.Text
  featuredImage String?
  status        String    @default("draft")
  author        User?     @relation(fields: [authorId], references: [id])
  authorId      String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Person {
  id          String  @id @default(cuid())
  name        String
  title       String?
  bio         String? @db.Text
  photoUrl    String?
  category    String  @default("core")
  socialLinks Json?
  sortOrder   Int     @default(0)
}

model Project {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  link        String?
  sortOrder   Int     @default(0)
}

model Partner {
  id        String @id @default(cuid())
  name      String
  logoUrl   String?
  link      String?
  sortOrder Int    @default(0)
}

model Publication {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  link        String?
  category    String  @default("book")
  sortOrder   Int     @default(0)
}

model Video {
  id         String @id @default(cuid())
  title      String
  youtubeUrl String
  sortOrder  Int    @default(0)
}

model MediaItem {
  id         String   @id @default(cuid())
  filename   String
  url        String
  alt        String?
  mimeType   String?
  size       Int?
  createdAt  DateTime @default(now())
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.LongText
}
